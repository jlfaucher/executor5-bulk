  parse source . . s
  group = .TestGroup~new(s)
  group~add(.bug2003_guard_when.testGroup)

  if group~isAutomatedTest then return group

  testResult = group~suite~execute~~print

return testResult
-- End of entry point.

/* - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -*\
  Directives, Classes, or Routines.
\* - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -*/
::requires 'ooTest.frm'
::requires 'FileUtils.cls' -- for issueCmd

-- program used in bug#2003
::resource "guard_when"
    use arg n = 10
    b = .Buffer~new
    append = .Message~new(b, "ADD")
    do n
      append~reply
    end

    ::class Buffer

    ::method init
      expose n
      n = 0

    ::method add unguarded
      expose n
      guard on when n = n
      say "n" n
      n = n + 1
::END

/* class: bug2003_guard_when.testGroup - - - - - - - - - - - - - - - - - - - -*\

\* - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -*/
::class "bug2003_guard_when.testGroup" public subclass ooTestCase

::method makeTestPgm
    sa = .TemporaryTestFile~new(self, 'guard_when.rex')
    if \sa~exists then
        sa~createFromResource(guard_when)
    return sa~fullname  -- full name of the test program

::method test_guard_when_1
    outLines = .array~new -- will hold console output
    guard_when = self~makeTestPgm
    theCmd = 'rexx' guard_when
    theRC = issueCmd(theCmd, outLines)
    self~assertRC(0, theRC)
    self~assertEquals(10, outLines~items)
    /* index    item
         1      n 0
         2      n 1
        ..      ...
         9      n 8
        10      n 9
    */
    do i=0 to 9
        self~assertSame("n" i, outlines[i+1])
    end

-- End of class: bug2003_guard_when.testGroup
